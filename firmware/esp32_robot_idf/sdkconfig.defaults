# Defaults applied on first build (idf.py reconfigure regenerates sdkconfig
# from these). Per-target overrides go in sdkconfig.defaults.<target>.

# WebRTC needs network + SCTP-friendly LWIP buffer sizes. Camera + NimBLE
# both want PSRAM. PSRAM mode is set per-target since classic ESP32 uses
# external SPI PSRAM and S3 uses Octal PSRAM.

# Logging
CONFIG_LOG_DEFAULT_LEVEL_INFO=y

# Bluetooth (NimBLE — matches Arduino stack)
CONFIG_BT_ENABLED=y
CONFIG_BT_NIMBLE_ENABLED=y
CONFIG_BT_CONTROLLER_ONLY=n
CONFIG_BT_BLUEDROID_ENABLED=n

# Networking — bigger LWIP buffers help SCTP throughput on data channels.
CONFIG_LWIP_TCP_SND_BUF_DEFAULT=16384
CONFIG_LWIP_TCP_WND_DEFAULT=16384

# mbedTLS — libpeer needs DTLS; default subset usually works but be explicit
CONFIG_MBEDTLS_SSL_PROTO_DTLS=y
CONFIG_MBEDTLS_HARDWARE_AES=y
CONFIG_MBEDTLS_HARDWARE_SHA=y
# Mozilla root CA bundle — wss://signal.neevs.io needs server cert verification
# without us shipping a per-host PEM in flash.
CONFIG_MBEDTLS_CERTIFICATE_BUNDLE=y
CONFIG_MBEDTLS_CERTIFICATE_BUNDLE_DEFAULT_FULL=y

# Camera framebuffer in PSRAM
CONFIG_CAMERA_TASK_STACK_SIZE=4096

# Partition table — OTA needs two app slots + factory.
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"
