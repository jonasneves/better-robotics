#!/usr/bin/env bash
# Fast pre-commit checks. Bypassable with `git commit --no-verify` —
# CI is the binding layer; this is just fast feedback so common
# mistakes don't survive a 5-minute round-trip.
#
# Install: `make install-hooks` (sets core.hooksPath = .githooks).

set -e

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

# 1. Generated-UUIDs drift. Only fires when protocol/uuids.json is staged —
# casual commits on unrelated files don't pay for the regen.
if git diff --cached --name-only | grep -q '^protocol/uuids\.json$'; then
    python3 tools/gen-uuids.py >/dev/null
    GEN="firmware/esp32_robot_idf/main/uuids.h firmware/pi_robot/uuids.py public/uuids.js"
    if ! git diff --quiet -- $GEN; then
        echo "pre-commit: generated UUID files are out of sync with protocol/uuids.json"
        echo "  fix: make gen-uuids && git add $GEN"
        exit 1
    fi
fi

# 2. SW version stamp. Hashes the dashboard asset surface and rewrites
# public/sw.js's VERSION when the hash changes — bumping VERSION is
# what makes the browser see a new service worker and surface the
# "Reload to update" banner. Mirrors .github/workflows/stamp-sw-version.yml
# but folds the stamp into the user's own commit instead of a follow-up
# bot-commit. Only fires when public/* (excluding firmware bins + sw.js
# itself) is staged.
if git diff --cached --name-only \
    | grep -E '^public/' \
    | grep -vE '^public/firmware/|^public/sw\.js$' \
    | grep -q .; then
    HASH=$(find public -type f \
        \( -name '*.js' -o -name '*.css' -o -name '*.html' -o -name '*.svg' -o -name '*.json' \) \
        -not -path 'public/firmware/*' \
        -not -name 'sw.js' \
        | sort | xargs cat | shasum -a 256 | cut -c1-8)
    CUR=$(grep -E '^const VERSION = ' public/sw.js | sed 's/.*"\(.*\)".*/\1/')
    if [ "$HASH" != "$CUR" ]; then
        # Rewrite-and-mv form is portable; `sed -i` differs between
        # BSD (macOS) and GNU.
        sed "s|^const VERSION = .*|const VERSION = \"$HASH\";|" public/sw.js > public/sw.js.tmp \
            && mv public/sw.js.tmp public/sw.js
        git add public/sw.js
        echo "pre-commit: stamped sw.js VERSION = $HASH"
    fi
fi

# 3. Pure-function smoke tests. Sub-second. Catches regressions in
# format.js (and future pure helpers) before they reach CI.
make -s smoke
