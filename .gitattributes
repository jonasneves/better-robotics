# Hidden-prefix folders are encrypted with git-crypt + the personal key
# stored in Apple Keychain. After clone, run `gcp-unlock` (defined in
# dotfiles' .zshrc) to install the filter and decrypt the working tree.
.claude/**   filter=git-crypt diff=git-crypt
.docs/**     filter=git-crypt diff=git-crypt
.private/**  filter=git-crypt diff=git-crypt
.secret/**   filter=git-crypt diff=git-crypt
